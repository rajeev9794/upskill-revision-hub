    "acrName": {
      "value": "upskillregistry"
    },
    "acrResourceGroup": {
      "value": "upskill-rg"
    },
    "containerImage": {
      "value": "upskillregistry.azurecr.io/upskill:latest"
    },
    "containerPort": {
      "value": 3000
    }
  }
}
