# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=upskill-rg
AZURE_LOCATION=eastus
AZURE_APP_NAME=upskill-revision-hub-dev

# Container Registry
AZURE_REGISTRY_LOGIN_SERVER=upskillregistry.azurecr.io
AZURE_REGISTRY_USERNAME=upskilladmin
AZURE_REGISTRY_PASSWORD=your-registry-password

# App Service
WEBSITES_PORT=3000
NODE_ENV=production

# Optional: Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string
